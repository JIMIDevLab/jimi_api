# Template for .env (which is gitignored).
# Copy this file and fill in the secrets:
#   cp .env.example .env

# --- Required -----------------------------------------------------------------
# Mistral AI key — get one on https://console.mistral.ai
MISTRAL_API_KEY=

# --- Local port ---------------------------------------------------------------
# The api container is bound to 127.0.0.1:${API_PORT}:8080 — never public.
# The host's nginx vhost reverse-proxies jimi-api.julsql.fr → 127.0.0.1:8102.
API_PORT=8102

# --- Spring profile -----------------------------------------------------------
# SPRING_PROFILES_ACTIVE=prod

# --- DB credentials (defaults below match the bundled MariaDB) ----------------
# DB_NAME=JIMI
# DB_USERNAME=jimi
# DB_PASSWORD=jimi
# DB_ROOT_PASSWORD=root

# --- Standalone run (./run.sh, no docker) -------------------------------------
# DB_URL=jdbc:mariadb://localhost:3306/JIMI?useSSL=false&serverTimezone=Europe/Paris

# Template for .env (which is gitignored).
# Copy this file and fill in the secrets:
#   cp .env.example .env
#
# Every variable the API reads is listed here. Most have sane defaults (shown as
# the value or in a comment); only MISTRAL_API_KEY is strictly required to boot,
# and the calendar features need the OAuth + TOKEN_ENCRYPTION_KEY block.

# --- Required -----------------------------------------------------------------
# Mistral AI key — get one on https://console.mistral.ai
MISTRAL_API_KEY=
# Optional model override (default: mistral-small-latest)
# MISTRAL_MODEL=mistral-small-latest

# --- Calendar / OAuth (see docs/google-calendar-setup.md & microsoft-...) -----
# Encrypts OAuth tokens at rest. Generate with: openssl rand -base64 32
# Blank/invalid => calendar connection disabled, but the API still boots.
TOKEN_ENCRYPTION_KEY=
# Deep link / web URL the app is bounced back to after linking a calendar.
APP_RETURN_URL=jimi://connected

# Google Cloud OAuth client (APIs & Services -> Credentials -> OAuth client ID).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an Authorized redirect URI on that OAuth client.
GOOGLE_REDIRECT_URI=https://jimi-api.julsql.fr/oauth/google/callback

# Microsoft / Outlook OAuth client (Entra ID -> App registrations).
# Leave client id/secret blank to keep Microsoft disabled.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://jimi-api.julsql.fr/oauth/microsoft/callback
# "common" = personal + work accounts; or a specific tenant id.
MICROSOFT_TENANT=common

# --- Data retention -----------------------------------------------------------
# Scheduled purge of inactive users (all their data, revoking calendar tokens)
# and old conversation memory. Days are inactivity windows; cron is server time.
RETENTION_ENABLED=true
RETENTION_USER_DAYS=180
RETENTION_CONTEXT_DAYS=3
RETENTION_CRON=0 30 3 * * *

# --- Timezone -----------------------------------------------------------------
# Container/JVM default zone (fallback when the client doesn't send one).
TZ=Europe/Paris

# --- Local port ---------------------------------------------------------------
# The api container is bound to 127.0.0.1:${API_PORT}:8080 — never public.
# The host's nginx vhost reverse-proxies jimi-api.julsql.fr → 127.0.0.1:8102.
API_PORT=8102

# --- Spring profile -----------------------------------------------------------
# SPRING_PROFILES_ACTIVE=prod

# --- DB credentials (defaults below match the bundled MariaDB) ----------------
# DB_NAME=JIMI
# DB_USERNAME=jimi
# DB_PASSWORD=jimi
# DB_ROOT_PASSWORD=root

# --- Standalone run (./run.sh, no docker) -------------------------------------
# DB_URL=jdbc:mariadb://localhost:3306/JIMI?useSSL=false&serverTimezone=Europe/Paris
